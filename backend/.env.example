# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./stockmind.db

# ── External APIs ───────────────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key_here

# ── Supabase Auth ────────────────────────────────────────────────────────────
# From: Supabase dashboard → Project Settings → JWT
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── AI Fallback (Groq) ───────────────────────────────────────────────────────
# Used when users don't provide their own key. Get free key: console.groq.com
GROQ_API_KEY=your_groq_key_here
GROQ_FALLBACK_ENABLED=false
GROQ_FALLBACK_DAILY_LIMIT=10

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list for production. Leave as * for local dev.
ALLOWED_ORIGINS=*
